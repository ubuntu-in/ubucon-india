---
import { getCollection, getEntry } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { dateRange } from "../lib/dates";

const site = await getEntry("site", "site");
const s = site?.data;

const editions = (await getCollection("event")).sort(
  (a, b) => a.data.startDate.getTime() - b.data.startDate.getTime(),
);
const now = new Date();
const featured = editions.find((e) => e.data.endDate >= now) ?? editions.at(-1);

const socialIcon: Record<string, string> = {
  x: "twitter-x",
  mastodon: "mastodon",
  linkedin: "linkedin",
  github: "github",
};
const formLive = Boolean(s?.formgridId);
---

<Base
  title="Contact"
  description="Get in touch with the UbuCon India organising team."
>
  <section class="p-strip">
    <div class="u-container">
      <h1 class="h-xl u-aubergine">Contact Us</h1>
      <p class="body contact-lede">
        Have a question about UbuCon India 2026? Reach out to the organising
        team - we'd love to hear from you.
      </p>

      <div class="contact-grid">
        <div class="p-card contact-card">
          <h2 class="card-title">Send us a message</h2>
          <form
            class="contact-form"
            action={`https://formgrid.dev/api/f/${s?.formgridId}`}
            method="POST"
          >
            <div class="field-row">
              <div class="field">
                <label for="name">Full name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Your name"
                  required
                />
              </div>
              <div class="field">
                <label for="email">Email address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  required
                />
              </div>
            </div>
            <div class="field">
              <label for="subject">Subject</label>
              <input
                type="text"
                id="subject"
                name="user_subject"
                placeholder="What's this about?"
              />
            </div>
            <div class="field">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Write your message..."
                required></textarea>
            </div>
            {
              !formLive && (
                <p class="p-notification--caution form-note">
                  <span class="p-notification__content">
                    <span class="p-notification__message">
                      The form isn't wired up yet - add a Formgrid form ID in
                      <code>src/content/site.yaml</code> to make it live.
                      Meanwhile, please email us directly.
                    </span>
                  </span>
                </p>
              )
            }
            <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
            <div
              class="h-captcha"
              data-sitekey="4984ef7a-17c0-4828-a638-9b1e7158f138"
              data-theme="dark"
            >
            </div>
            <button
              type="submit"
              class="p-button--positive"
              disabled={!formLive}>Send message</button
            >
          </form>
        </div>

        <!-- ── Reach us directly ── -->
        <div class="p-card contact-card">
          <h2 class="card-title">Reach us directly</h2>
          {
            s?.contacts?.map((c) => (
              <p class="reach">
                <span class="reach__label">{c.label}</span>
                <a class="reach__email" href={`mailto:${c.email}`}>
                  {c.email}
                </a>
              </p>
            ))
          }

          <hr class="reach__rule" />

          {
            featured && (
              <p class="reach reach--venue">
                <Icon name="geo-alt-fill" class="i-accent" size={22} />
                <span>
                  <span class="reach__label">Venue</span>
                  <span class="reach__venue">
                    {featured.data.city} |{" "}
                    {dateRange(featured.data.startDate, featured.data.endDate)}
                  </span>
                </span>
              </p>
            )
          }

          {
            s?.socials && (
              <div class="reach reach--social">
                <span class="reach__label">Follow us</span>
                <span class="socials">
                  {Object.entries(s.socials).map(([k, href]) => (
                    <a
                      href={href}
                      rel="noopener"
                      target="_blank"
                      aria-label={`UbuCon India on ${k}`}
                    >
                      <Icon name={socialIcon[k] ?? "link-45deg"} size={22} />
                    </a>
                  ))}
                </span>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-lede {
    max-width: 36rem;
    margin-bottom: 2.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.12fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* Cards: Vanilla p-card look but square corners to match design (rounded 2px). */
  .contact-card {
    border-radius: 2px;
    padding: 2rem;
  }
  .card-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--u-aubergine);
    margin: 0 0 1.25rem;
  }

  .contact-form {
    display: grid;
    gap: 1.25rem;
  }
  .field {
    display: grid;
    gap: 0.5rem;
  }
  .field label {
    font-weight: 600;
    color: var(--u-aubergine);
    font-size: 0.95rem;
    margin: 0;
  }
  .field :global(input),
  .field :global(textarea) {
    margin: 0;
    width: 100%;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .contact-form :global(.p-button--positive) {
    margin: 0;
    justify-self: start;
  }
  .form-note {
    margin: 0;
  }

  /* Reach us directly */
  .reach {
    margin: 0 0 1.5rem;
    display: grid;
    gap: 0.25rem;
  }
  .reach__label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    font-weight: 600;
    color: #666;
  }
  .reach__email {
    font-size: 1.125rem;
    font-weight: 500;
  }
  .reach__rule {
    border: 0;
    border-top: 1px solid #ccc;
    margin: 0.5rem 0 1.5rem;
  }
  .reach--venue {
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.75rem;
  }
  .reach--venue :global(svg) {
    color: var(--u-orange);
  }
  .reach__venue {
    color: var(--u-aubergine);
    font-weight: 500;
  }
  .reach--social {
    gap: 0.6rem;
  }
  .socials {
    display: flex;
    gap: 1.1rem;
  }
  .socials a {
    color: var(--u-aubergine);
  }
  .socials a:hover {
    color: var(--u-orange);
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .field-row {
      grid-template-columns: 1fr;
    }
    .contact-card {
      padding: 1.5rem;
    }
  }
</style>
