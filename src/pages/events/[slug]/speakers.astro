---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import SpeakerGrid from "../../../components/SpeakerGrid.svelte";
import { getImage } from "astro:assets";
import { url } from "../../../lib/url";

const opt = async (photo) =>
  photo
    ? (await getImage({ src: photo, format: "webp", width: 520 })).src
    : undefined;

export async function getStaticPaths() {
  const editions = await getCollection("event");
  return editions.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const e = entry.data;
const slug = entry.id;

const speakers = await Promise.all(
  (await getCollection("lineup", ({ data }) => data.edition.includes(slug)))
    .map(({ data: s }) => s)
    .sort(
      (a, b) =>
        Number(b.featured) - Number(a.featured) || a.name.localeCompare(b.name),
    )
    .map(async (s) => ({
      name: s.name,
      role: s.affiliation,
      photo: await opt(s.photo),
      category: s.track,
      featured: s.featured,
    })),
);

const crumbs = [
  { label: "Events", href: url("/events") },
  { label: e.name, href: url(`/events/${slug}`) },
  { label: "Speakers" },
];
---

<Base title={`Speakers · ${e.name}`} description={`Speakers for ${e.name}.`}>
  <section class="p-strip">
    <div class="u-container">
      <Breadcrumbs items={crumbs} />
      <h1 class="h-xl u-aubergine">Speakers</h1>
      <p class="body speakers-lede">
        Meet the people sharing their ideas, stories and expertise at {e.name}.
      </p>

      {
        speakers.length === 0 ? (
          <p class="body empty">
            Speakers will be announced after the call for proposals closes.
          </p>
        ) : (
          <SpeakerGrid client:load speakers={speakers} />
        )
      }
    </div>
  </section>
</Base>

<style>
  .speakers-lede {
    max-width: 42rem;
    margin-bottom: 2rem;
  }
  .empty {
    margin-top: 1.5rem;
  }
</style>
