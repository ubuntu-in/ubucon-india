---
import { url } from "../lib/url";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const here = Astro.url.pathname.slice(base.length).replace(/\/$/, "") || "/";
const slug = here.match(/^\/events\/([^/]+)/)?.[1];

const links = slug
  ? [
      { label: "Home", href: url("/") },
      { label: "Overview", href: url(`/events/${slug}`) },
      { label: "Speakers", href: url(`/events/${slug}/speakers`) },
      { label: "Schedule", href: url(`/events/${slug}/schedule`) },
      { label: "Sponsors", href: url(`/events/${slug}/sponsors`) },
      { label: "Venue", href: url(`/events/${slug}/venue`) },
    ]
  : [
      { label: "Home", href: url("/") },
      { label: "About", href: url("/about") },
      { label: "Events", href: url("/events") },
      { label: "Contact", href: url("/contact") },
    ];

const isActive = (href: string) =>
  href !== "#" && (href.slice(base.length).replace(/\/$/, "") || "/") === here;
---
<style>
  .p-navigation__toggle--open .p-icon--menu,
  .p-navigation__toggle--close .p-icon--close {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>

<header id="navigation" class="p-navigation is-dark is-sticky">
  <div class="p-navigation__row--25-75">
    <div class="p-navigation__banner">
      <div class="p-navigation__tagged-logo">
        <a
          class="p-navigation__link"
          href={url("/")}
          aria-label="UbuCon India home"
        >
          <div class="p-navigation__logo-tag">
            <img
              class="p-navigation__logo-icon"
              src={url("/img/ubucon-logo.svg")}
              alt="UbuCon India"
            />
          </div>
          <span class="p-navigation__logo-title">UbuCon India</span>
        </a>
      </div>
      <ul class="p-navigation__items">
        <li class="p-navigation__item">
          <a
            class="p-navigation__toggle--open"
            href="#navigation"
            aria-label="Open menu"
          >
            <i class="p-icon--menu"></i>
          </a>
          <a
            class="p-navigation__toggle--close"
            href="#"
            aria-label="Close menu"
          >
            <i class="p-icon--close"></i>
          </a>
        </li>
      </ul>
    </div>
    <nav class="p-navigation__nav" aria-label="Main">
      <ul class="p-navigation__items">
        {
          links.map((l) => (
            <li
              class:list={[
                "p-navigation__item",
                { "is-selected": isActive(l.href) },
              ]}
            >
              <a
                class="p-navigation__link"
                href={l.href}
                aria-current={isActive(l.href) ? "page" : undefined}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
