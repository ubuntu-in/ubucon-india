---
import { url } from '../lib/url';

// Event-specific pages (Schedule, Speakers, Venue, Sponsors) are not in the
// global nav — they live in-page. Home + About are the only top-level routes.
const links = [
  { label: 'Home', href: url('/') },
  { label: 'About', href: url('/about') },
];

// Astro.url.pathname ALREADY includes the base ('/india/…'); the links are
// already url()-prefixed. Normalise both (strip trailing slash) and compare —
// do NOT re-run pathname through url() or it double-prefixes to '/india/india'.
const here = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => href !== '#' && href.replace(/\/$/, '') === here;
---

<!--
  Vanilla Framework p-navigation, light theme, sticky.
  Mobile toggle uses Vanilla's zero-JS `:target` mechanism: the open toggle
  links to #navigation (this header's id), which flips `:target` and reveals
  `.p-navigation__nav`; the close toggle links to #, clearing the target.
  No checkbox hack, no JS — pure Vanilla CSS.
-->
<style>
  .p-navigation__toggle--open .p-icon--menu,
  .p-navigation__toggle--close .p-icon--close {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>

<header id="navigation" class="p-navigation is-dark is-sticky">
  <div class="p-navigation__row--25-75">
    <div class="p-navigation__banner">
      <div class="p-navigation__tagged-logo">
        <a class="p-navigation__link" href={url('/')} aria-label="UbuCon India home">
          <div class="p-navigation__logo-tag">
            <img class="p-navigation__logo-icon" src={url('/img/ubucon-logo.svg')} alt=""/>
          </div>
          <span class="p-navigation__logo-title">UbuCon India</span>
        </a>
      </div>
      <ul class="p-navigation__items">
        <li class="p-navigation__item">
          <a class="p-navigation__toggle--open" href="#navigation" aria-label="Open menu">
            <i class="p-icon--menu"></i>
          </a>
          <a class="p-navigation__toggle--close" href="#" aria-label="Close menu">
            <i class="p-icon--close"></i>
          </a>
        </li>
      </ul>
    </div>
    <nav class="p-navigation__nav" aria-label="Main">
      <ul class="p-navigation__items">
        {
          links.map((l) => (
            <li class:list={['p-navigation__item', { 'is-selected': isActive(l.href) }]}>
              <a class="p-navigation__link" href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
